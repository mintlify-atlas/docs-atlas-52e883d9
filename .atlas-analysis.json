  "keyFeatures": [
    "JWT authentication with Defra ID integration",
    "Role-based access control for bank details and documents",
    "Bank account management for local authorities",
    "Document storage and retrieval with metadata",
    "MongoDB with distributed locking",
    "Forward proxy support for external requests",
    "CloudWatch metrics and distributed tracing",
    "Health checks and monitoring"
